# 打砖块游戏 (Breakout) .gitignore 文件
# 此文件指定了 Git 应该忽略的文件和目录

# ==========================================
# Python 相关
# ==========================================

# Python 缓存目录
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境
.venv/
venv/
ENV/
env/

# Python 打包
*.egg-info/
dist/
build/
.eggs/
*.egg

# ==========================================
# PyInstaller 相关
# ==========================================

# PyInstaller 生成的文件
*.spec
# dist/ 和 build/ 已经在上面列出

# ==========================================
# 运行时生成的文件
# ==========================================

# 数据目录（运行时生成的配置和排行榜）
# 注意：如果需要保留默认数据文件，可以取消下面一行的注释
# 并确保只忽略运行时生成的文件，而不是默认数据文件
data/

# 日志文件
logs/
*.log

# 临时文件
tmp/
temp/
*.tmp
*.temp

# ==========================================
# 调试和截图相关
# ==========================================

# 调试截图
screenshots/
*.png
*.jpg
*.jpeg
*.bmp

# 核心转储文件
*.core
*.stackdump

# ==========================================
# 编译生成的可执行文件
# ==========================================

# Windows 可执行文件
*.exe
*.bat
*.cmd

# macOS 可执行文件
*.app
*.dmg

# Linux 可执行文件
*.out
*.elf

# ==========================================
# IDE 和编辑器配置
# ==========================================

# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp

# ==========================================
# 操作系统相关
# ==========================================

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Linux
*~

# ==========================================
# 资源缓存
# ==========================================

# 媒体文件缓存
*.cache/
cache/

# 字体缓存
*.font.cache

# 其他缓存
*.cached
